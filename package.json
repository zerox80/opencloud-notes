{
  "name": "opencloud-notes",
  "version": "0.1.0",
  "private": true,
  "description": "Modern file-native notes app for OpenCloud.",
  "license": "AGPL-3.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch --mode development",
    "check:types": "vue-tsc --noEmit",
    "test:unit": "vitest --run",
    "validate": "vue-tsc --noEmit && vitest --run && vite build"
  },
  "devDependencies": {
    "@opencloud-eu/design-system": "^6.0.0",
    "@opencloud-eu/extension-sdk": "^6.0.0",
    "@opencloud-eu/tsconfig": "^6.0.0",
    "@opencloud-eu/web-client": "^6.0.0",
    "@opencloud-eu/web-pkg": "^6.0.0",
    "@types/node": "24.12.0",
    "happy-dom": "^20.0.0",
    "pinia": "3.0.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.1",
    "vue": "^3.4.21",
    "vue-concurrency": "^5.0.3",
    "vue-tsc": "^3.2.6",
    "vue3-gettext": "^4.0.0-beta.1",
    "zod": "^4.3.0"
  },
  "peerDependencies": {
    "@opencloud-eu/design-system": "^6.0.0",
    "@opencloud-eu/web-client": "^6.0.0",
    "@opencloud-eu/web-pkg": "^6.0.0"
  }
}
